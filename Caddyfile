{
    email easyiotechnologies@gmail.com
}

oruerp.com, get-oru.com {
    # Proxy sitemap and robots specifically to backend
    handle /sitemap.xml {
        reverse_proxy backend:3000
    }
    handle /robots.txt {
        reverse_proxy backend:3000
    }

    # Reverse proxy for backend API requests
    handle /api/* {
        reverse_proxy backend:3000
    }

    # Everything else to frontend
    handle /* {
        reverse_proxy frontend:80
    }

    # Optional: Log file
    log {
        output file /var/log/caddy/access.log
    }
}
